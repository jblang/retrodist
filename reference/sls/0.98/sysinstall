if [ $# = 0 ]; then
	PrintUsage;
elif [ $1 = "-view" ]; then 
	ShowInstalled;
elif [ $1 = "-all" ]; then 
	DoInstall a;
	DoInstall b;
	DoInstall c;
	DoInstall x;
elif [ $1 = "-base" ]; then 
	DoInstall a;
	DoInstall b;
	DoInstall c;
elif [ $1 = "-mini" ]; then 
	DoInstall a;
elif [ $1 = "-rest" ]; then 
	DoInstall b;
	DoInstall c;
elif [ $1 = "-X11" ]; then 
	DoInstall x;
elif [ $1 = "-remove" -a $# = 2 ]; then
	RemovePkg $2
elif [ $1 = "-install" -a $# = 2 ]; then
	InstallPkg $2
elif [ $1 = "-series" -a $# = 2 ]; then
	DoInstall $2
elif [ $1 = "-extract" -a $# = 2 ]; then
	if [ -f $INSTDIR/$2 ]; then
		if [ -f $INSTSCRDIR/$2 ]; then
			cp $INSTSCRDIR/$2 $INSTTOPDIR/$INSTSCRIPT
			(cd $INSTROOT; sh $INSTSCRDIR/$2 -extract;)
			(cd $INSTROOT; tar -czlpf - -T $INSTDIR/$2 ) > $2.taz
			(cd $INSTROOT; sh $INSTSCRDIR/$2 -retract;)
			rm $INSTTOPDIR/$INSTSCRIPT
		else
			(cd $INSTROOT; tar -czlpf - -T $INSTDIR/$2 ) > $2.taz
		fi
	else
		echo "$INSTDIR/$2 not found";
	fi;
elif [ $1 = "-disk" ]; then
	if [ $# = 1 ] ; then
		InstallDisk Disk
	else
		InstallDisk $2
	fi
elif [ $1 = "-mount ]; then
	MountDisk;
elif [ $1 = "-unmount ]; then
	UnmountDisk;
else
	PrintUsage;
fi;
