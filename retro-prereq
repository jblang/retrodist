#!/usr/bin/env bash
# Install the host tools used by Python and custom media hooks, then install Retro.
set -euo pipefail

RETRO_D=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
VENV_D=$RETRO_D/.venv
DRY_RUN=0

usage() {
    echo "Usage: retro-prereq [--dry-run]"
}

if [[ ${1:-} == --dry-run ]]; then
    DRY_RUN=1
    shift
fi
if [[ $# -ne 0 ]]; then
    usage >&2
    exit 2
fi

run() {
    printf '  '
    printf '%q ' "$@"
    echo
    if [[ $DRY_RUN -eq 0 ]]; then
        "$@"
    fi
}

privileged() {
    if [[ $(id -u) -eq 0 ]]; then
        run "$@"
    elif command -v sudo >/dev/null 2>&1; then
        run sudo "$@"
    else
        echo "sudo is required to install system packages" >&2
        exit 1
    fi
}

install_system_packages() {
    local mingw_prefix
    case "$(uname -s)" in
    Darwin)
        command -v brew >/dev/null 2>&1 || {
            echo "Homebrew is required on macOS: https://brew.sh/" >&2
            exit 1
        }
        run brew install python qemu mtools unzip wget bchunk
        ;;
    Linux)
        if command -v apt-get >/dev/null 2>&1; then
            privileged apt-get install python3 python3-venv qemu-system-x86 qemu-system-gui qemu-utils mtools unzip wget bchunk
        elif command -v dnf >/dev/null 2>&1; then
            privileged dnf install python3 qemu-system-x86-core qemu-img qemu-ui-gtk mtools unzip wget bchunk
        elif command -v pacman >/dev/null 2>&1; then
            privileged pacman -S --needed python qemu-system-x86 qemu-ui-gtk qemu-img mtools unzip wget bchunk
        else
            echo "No supported Linux package manager found (apt-get, dnf, or pacman)" >&2
            exit 1
        fi
        ;;
    MSYS_NT* | MINGW*_NT* | UCRT*_NT* | CLANG*_NT*)
        command -v pacman >/dev/null 2>&1 || {
            echo "pacman is required in MSYS2" >&2
            exit 1
        }
        case "${MSYSTEM:-}" in
        MINGW32) mingw_prefix=mingw-w64-i686 ;;
        MINGW64) mingw_prefix=mingw-w64-x86_64 ;;
        UCRT64) mingw_prefix=mingw-w64-ucrt-x86_64 ;;
        CLANG32) mingw_prefix=mingw-w64-clang-i686 ;;
        CLANG64) mingw_prefix=mingw-w64-clang-x86_64 ;;
        CLANGARM64) mingw_prefix=mingw-w64-clang-aarch64 ;;
        *)
            echo "Run retro-prereq from an MSYS2 MinGW shell" >&2
            exit 1
            ;;
        esac
        run pacman -S --needed "${mingw_prefix}-python" "${mingw_prefix}-qemu" mtools unzip wget
        ;;
    *)
        echo "Unsupported host: $(uname -s)" >&2
        exit 1
        ;;
    esac
}

find_python() {
    if command -v python3 >/dev/null 2>&1; then
        command -v python3
    elif command -v python >/dev/null 2>&1; then
        command -v python
    else
        return 1
    fi
}

echo "Installing Python and host tools used by Retro:"
install_system_packages
hash -r

if [[ $DRY_RUN -eq 1 ]]; then
    echo "Creating the virtual environment:"
    run python3 -m venv "$VENV_D"
    echo "Installing Retro into the virtual environment:"
    run "$VENV_D/bin/python" -m pip install -e "$RETRO_D"
    exit
fi

PYTHON=$(find_python) || {
    echo "Python was not found after package installation" >&2
    exit 1
}
if [[ ! -d $VENV_D ]]; then
    echo "Creating the virtual environment:"
    run "$PYTHON" -m venv "$VENV_D"
fi

if [[ -x $VENV_D/bin/python ]]; then
    VENV_PYTHON=$VENV_D/bin/python
elif [[ -x $VENV_D/Scripts/python.exe ]]; then
    VENV_PYTHON=$VENV_D/Scripts/python.exe
else
    echo "The virtual environment does not contain Python: $VENV_D" >&2
    exit 1
fi

echo "Installing Retro into the virtual environment:"
run "$VENV_PYTHON" -m pip install -e "$RETRO_D"

echo
echo "Retro is ready. Activate it with:"
if [[ -f $VENV_D/bin/activate ]]; then
    echo "  source .venv/bin/activate"
else
    echo "  source .venv/Scripts/activate"
fi
