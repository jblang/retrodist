#!/usr/bin/env bash
# shellcheck disable=SC2034
# Downloads, extracts, and runs retro distros
# Entry point: source the hostlib modules, parse CLI args, print config,
# and dispatch to the selected top-level retro command.
RETRO_D=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
HOSTLIB_D=$RETRO_D/hostlib
GUESTLIB_D=$RETRO_D/guestlib

# temp directory automatically cleaned up on exit
TEMP_D=$(mktemp -d)
RETRO_COMMAND_STARTED=0
# shellcheck disable=SC2329 # Invoked by the EXIT trap.
# Remove temporary files and report command status.
retro_exit_cleanup() {
  local status=$?
  if [[ ${RETRO_COMMAND_STARTED:-0} == "1" ]]; then
    if [[ $status -eq 0 ]]; then
      log_info "Completed retro $COMMAND for $CONFNAME"
    else
      log_error "retro $COMMAND failed for $CONFNAME (status $status)"
    fi
  fi
  rm -rf "$TEMP_D"
}
trap retro_exit_cleanup EXIT

for LIB in "$HOSTLIB_D"/*.sh; do
  # shellcheck source=/dev/null
  source "$LIB"
done

# Print CLI usage.
retro_print_usage() {
cat <<EOF
Usage: $(basename "$0") [COMMAND] [CONFIG] [OPTIONS]

Commands:
  help      show this help text
  boot      boot the distro in QEMU; calls extract
  install   boot the distro from install media in QEMU; use boot.img as fda and install.iso as hdc
  extract   extract files for the distro; calls download
  download  download source files for the distro or CD-ROM
  tagfile   generate default.tag from install media; calls extract
  package   create a tar with the QEMU image files and startup script
  prereq    install host prerequisites with the current OS package manager
  reset     remove the QEMU images and extracted files for the distro

Config:
  If specified, should be the name of a config directory.
  Defaults to the current directory.

Additional options are passed to QEMU verbatim.

EOF
}

# Print help for the top-level help command.
retro_help() {
  retro_print_usage
}

# Consume a recognized command; otherwise ignore the remaining arguments and
# show help instead of treating the first argument as a configuration path.
COMMAND=help
if [[ $# -ge 1 ]]; then
  case $1 in
    help | boot | install | extract | download | tagfile | reset | package | prereq)
      COMMAND=$1
      shift
      ;;
    *)
      set --
      ;;
  esac
fi

# next parameter should be a config directory; default to pwd.
# Consume it as CONFIG only when it is not an option (so QEMU options following
# the command are left for QEMU) regardless of how many further args remain.
if [[ $# -ge 1 && $1 != -* ]]; then
  if [[ -d "$1" ]]; then
    DISTRO_D=$(cd "$1" && pwd)
    shift
  elif [[ -d "$RETRO_D/$1" ]]; then
    DISTRO_D=$(cd "$RETRO_D/$1" && pwd)
    shift
  else
    die "Configuration $1 doesn't exist"
  fi
else
  DISTRO_D=$PWD
fi
CONFNAME=$DISTRO_D
case "$CONFNAME" in
  "$RETRO_D"/*)
    CONFNAME=${CONFNAME#"$RETRO_D"/}
    ;;
esac

QEMU_D=$DISTRO_D/qemu.d
EXTRACT_D=$QEMU_D
TAGFILE_D=$DISTRO_D/tagfile.d
if qemu_config_find_file cdrom.txt >/dev/null; then
  DOWNLOAD_D=$QEMU_D
else
  DOWNLOAD_D=$DISTRO_D/download.d
fi
# output configuration details
cat <<EOF
🐧 Retro Distro Playground by J.B. Langston

Command:    $COMMAND
Config:     $DISTRO_D
QEMU:       $QEMU_D

EOF

# run the selected command
if [[ $COMMAND != "help" ]]; then
  RETRO_COMMAND_STARTED=1
  log_info "Starting retro $COMMAND for $CONFNAME"
  log_debug "Temporary directory: $TEMP_D"
fi
RUN_STATUS=0
case $COMMAND in
  help) retro_help;;
  download) retro_download || RUN_STATUS=$?;;
  extract) retro_extract || RUN_STATUS=$?;;
  tagfile) retro_tagfile || RUN_STATUS=$?;;
  boot) retro_boot "$@" || RUN_STATUS=$?;;
  install) retro_install "$@" || RUN_STATUS=$?;;
  package) retro_package "$@" || RUN_STATUS=$?;;
  prereq) retro_prereq "$@" || RUN_STATUS=$?;;
  reset) retro_reset || RUN_STATUS=$?;;
esac
exit "$RUN_STATUS"
