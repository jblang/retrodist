#!/usr/bin/env bash
# shellcheck disable=SC2034
# Downloads, extracts, and runs retro distros
# Entry point: source the hostlib modules, parse CLI args, print config,
# and dispatch to the selected top-level retro command.
RETRO_D=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
HOSTLIB_D=$RETRO_D/hostlib
GUESTLIB_D=$RETRO_D/guestlib

TEMP_D=
RETRO_COMMAND_STARTED=0
# shellcheck disable=SC2329 # Invoked by the EXIT trap.
# Remove temporary files and report command status.
retro_exit_cleanup() {
  local status=$?
  if [[ ${RETRO_COMMAND_STARTED:-0} == "1" ]]; then
    if [[ $status -eq 0 ]]; then
      log_info "Completed retro $COMMAND for $CONFNAME"
    else
      log_error "retro $COMMAND failed for $CONFNAME (status $status)"
    fi
  fi
  [[ -z "${TEMP_D:-}" ]] || rm -rf "$TEMP_D"
}

for LIB in "$HOSTLIB_D"/*.sh; do
  # shellcheck source=/dev/null
  source "$LIB"
done

# Print CLI usage.
retro_print_usage() {
cat <<EOF
Usage: $(basename "$0") COMMAND [CONFIG]

Commands:
  help      show this help text
  boot      boot the distro in QEMU; calls extract
  install   boot the distro from install media in QEMU; use boot.img as fda and install.iso as hdc
  extract   extract files for the distro; calls download
  download  download source files for the distro or CD-ROM
  tagfile   generate default.tag from install media; calls extract
  package   create a tar with the QEMU image files and startup script
  prereq    install host prerequisites with the current OS package manager
  reset     remove the QEMU images and extracted files for the distro

Config:
  If specified, should be the name of a config directory.
  Defaults to the current directory.

EOF
}

# Print help for the top-level help command.
# shellcheck disable=SC2329 # Selected dynamically through COMMAND_HANDLER.
retro_help() {
  retro_print_usage
}

# Resolves CONFIG from the current directory or repository root.
retro_resolve_config() {
  local config=${1:-}

  if [[ -z "$config" ]]; then
    DISTRO_D=$PWD
  elif [[ -d "$config" ]]; then
    DISTRO_D=$(cd "$config" && pwd)
  elif [[ -d "$RETRO_D/$config" ]]; then
    DISTRO_D=$(cd "$RETRO_D/$config" && pwd)
  else
    die "Configuration $config doesn't exist"
  fi
}

# Validates COMMAND and selects its top-level handler.
retro_select_handler() {
  case $COMMAND in
    help) COMMAND_HANDLER=retro_help ;;
    download) COMMAND_HANDLER=retro_download ;;
    extract) COMMAND_HANDLER=retro_extract ;;
    tagfile) COMMAND_HANDLER=retro_tagfile ;;
    boot) COMMAND_HANDLER=retro_boot ;;
    install) COMMAND_HANDLER=retro_install ;;
    package) COMMAND_HANDLER=retro_package ;;
    prereq) COMMAND_HANDLER=retro_prereq ;;
    reset) COMMAND_HANDLER=retro_reset ;;
    *)
      log_error "Unknown command: $COMMAND"
      retro_print_usage >&2
      return 1
      ;;
  esac
}

# Parses COMMAND [CONFIG], resolving CONFIG before validating COMMAND.
retro_parse_args() {
  if [[ $# -eq 0 ]]; then
    retro_print_usage >&2
    return 1
  elif [[ $# -gt 2 ]]; then
    log_error "Too many arguments; expected COMMAND [CONFIG]"
    retro_print_usage >&2
    return 1
  fi

  COMMAND=$1
  retro_resolve_config "${2:-}" || return 1
  retro_select_handler
}

# Derives the generated-state paths for the selected config.
retro_init_paths() {
  CONFNAME=$DISTRO_D
  case "$CONFNAME" in
    "$RETRO_D"/*) CONFNAME=${CONFNAME#"$RETRO_D"/} ;;
  esac

  QEMU_D=$DISTRO_D/qemu.d
  EXTRACT_D=$QEMU_D
  TAGFILE_D=$DISTRO_D/tagfile.d
  if config_find_file cdrom.txt >/dev/null; then
    DOWNLOAD_D=$QEMU_D
  else
    DOWNLOAD_D=$DISTRO_D/download.d
  fi
}

# Prints the selected command and generated-state paths.
retro_print_context() {
  cat <<EOF
🐧 Retro Distro Playground by J.B. Langston

Command:    $COMMAND
Config:     $DISTRO_D
QEMU:       $QEMU_D

EOF
}

# Runs the selected command and reports it through the EXIT trap.
retro_run_command() {
  local run_status=0

  if [[ $COMMAND != help ]]; then
    RETRO_COMMAND_STARTED=1
    log_info "Starting retro $COMMAND for $CONFNAME"
    log_debug "Temporary directory: $TEMP_D"
  fi
  "$COMMAND_HANDLER" || run_status=$?
  return "$run_status"
}

retro_main() {
  retro_parse_args "$@" || return 1
  retro_init_paths || return 1
  TEMP_D=$(mktemp -d) || die "Could not create temporary directory"
  trap retro_exit_cleanup EXIT
  retro_print_context
  retro_run_command
}

retro_main "$@"
