#!/usr/bin/env bash
# Runs a jumpbox for retro Linux distros to talk to
set -euo pipefail
SCRIPTDIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
JUMPHOME=${JUMPHOME:-$SCRIPTDIR/.retrojump}
HOST_OS=$(uname -s)
HOST_ARCH=$(uname -m)
DEBIAN_CODENAME=trixie
DEBIAN_RELEASE=13
JUMP_SSH_PORT=${JUMP_SSH_PORT:-2222}
JUMP_NET_MAC_INTERNET=52:54:00:12:34:56
JUMP_NET_MAC_RETRONET=52:54:00:12:34:57

# temp directory automatically cleaned up on exit
TEMPDIR=$(mktemp -d)
SEEDIMG=$TEMPDIR/seed.iso
trap 'rm -rf "$TEMPDIR"' EXIT

jump_configure_platform() {
  case "$HOST_OS/$HOST_ARCH" in
    Linux/*)
      DEBIAN_ARCH=amd64
      QEMU_BIN=qemu-system-x86_64
      QEMU_MACHINE_ARGS="-machine accel=kvm,type=q35 -cpu host"
      QEMU_NET_DEVICE=virtio-net-pci
      QEMU_EXTRA_ARGS=""
      ;;
    Darwin/x86_64)
      DEBIAN_ARCH=amd64
      QEMU_BIN=qemu-system-x86_64
      QEMU_MACHINE_ARGS="-machine accel=hvf,type=q35 -cpu host"
      QEMU_NET_DEVICE=virtio-net-pci
      QEMU_EXTRA_ARGS=""
      ;;
    Darwin/arm64)
      DEBIAN_ARCH=arm64
      QEMU_BIN=qemu-system-aarch64
      QEMU_MACHINE_ARGS="-machine accel=hvf,highmem=off,type=virt -cpu host"
      QEMU_NET_DEVICE=virtio-net-device
      QEMU_EXTRA_ARGS="-bios /opt/homebrew/share/qemu/edk2-aarch64-code.fd"
      ;;
    *)
      DEBIAN_ARCH=amd64
      QEMU_BIN=qemu-system-x86_64
      QEMU_MACHINE_ARGS="-machine accel=tcg,type=q35 -cpu max"
      QEMU_NET_DEVICE=virtio-net-pci
      QEMU_EXTRA_ARGS=""
      ;;
  esac

  CLOUDIMG=debian-$DEBIAN_RELEASE-genericcloud-$DEBIAN_ARCH.qcow2
  CLOUDIMG_URL="https://cloud.debian.org/images/cloud/$DEBIAN_CODENAME/latest/$CLOUDIMG"
  JUMPIMG=$JUMPHOME/retrojump-$DEBIAN_CODENAME-$DEBIAN_ARCH.qcow2
}

jump_check_platform_prereqs() {
  if ! command -v "$QEMU_BIN" >/dev/null 2>&1; then
    echo "Missing $QEMU_BIN in PATH" >&2
    exit 1
  fi

  if [[ -n "$QEMU_EXTRA_ARGS" && "$HOST_OS/$HOST_ARCH" == "Darwin/arm64" ]]; then
    if [[ ! -f /opt/homebrew/share/qemu/edk2-aarch64-code.fd ]]; then
      cat <<EOF >&2
Missing ARM UEFI firmware: /opt/homebrew/share/qemu/edk2-aarch64-code.fd
Reinstall or upgrade QEMU from Homebrew.
EOF
      exit 1
    fi
  fi
}

jump_check_ssh_port_available() {
  if command -v lsof >/dev/null 2>&1 && lsof -nP -iTCP:"$JUMP_SSH_PORT" -sTCP:LISTEN >/dev/null 2>&1; then
    cat <<EOF >&2
Host SSH forward port $JUMP_SSH_PORT is already in use.
Stop the existing process using that port, or run jump with a different port:

  JUMP_SSH_PORT=2223 ./jump run

Then connect with the same port:

  JUMP_SSH_PORT=2223 ./jump ssh
EOF
    exit 1
  fi
}

jump_system_drive_args() {
  case "$DEBIAN_ARCH" in
    arm64)
      echo "-drive if=none,id=system,format=qcow2,file=$JUMPIMG -device virtio-blk-device,drive=system"
      ;;
    *)
      echo "-drive if=virtio,format=qcow2,file=$JUMPIMG"
      ;;
  esac
}

jump_seed_drive_args() {
  case "$DEBIAN_ARCH" in
    arm64)
      echo "-drive if=none,id=seed,format=raw,file=$SEEDIMG,readonly=on -device virtio-blk-device,drive=seed"
      ;;
    *)
      echo "-drive file=$SEEDIMG,format=raw,media=cdrom,readonly=on"
      ;;
  esac
}

jump_make_seed_image() {
  local seed_dir=$TEMPDIR/seed
  mkdir -p "$seed_dir"
  cp "$TEMPDIR/userdata" "$seed_dir/user-data"
  cp "$TEMPDIR/metadata" "$seed_dir/meta-data"
  cp "$TEMPDIR/networkconfig" "$seed_dir/network-config"

  if command -v xorriso >/dev/null 2>&1; then
    xorriso -as mkisofs \
      -volid cidata \
      -joliet \
      -rock \
      -output "$SEEDIMG" \
      "$seed_dir" >/dev/null 2>&1
    return
  fi

  if command -v mkisofs >/dev/null 2>&1; then
    mkisofs \
      -volid cidata \
      -joliet \
      -rock \
      -output "$SEEDIMG" \
      "$seed_dir" >/dev/null 2>&1
    return
  fi

  if command -v hdiutil >/dev/null 2>&1; then
    hdiutil makehybrid \
      -iso \
      -joliet \
      -default-volume-name cidata \
      -o "$SEEDIMG" \
      "$seed_dir" >/dev/null
    return
  fi

  cat <<EOF >&2
No supported ISO builder found for the jump box seed image.
Install xorriso with Homebrew: brew install xorriso
EOF
  exit 1
}

jump_init() {
  mkdir -p $JUMPHOME
  wget --timestamping --directory-prefix="$JUMPHOME" "$CLOUDIMG_URL"
  cp $JUMPHOME/$CLOUDIMG $JUMPIMG
  qemu-img resize $JUMPIMG 20G

  # remove any old keys
  ssh-keygen -f "$HOME/.ssh/known_hosts" -R "[localhost]:$JUMP_SSH_PORT"
  if [[ ! -f $JUMPHOME/id_rsa ]]; then
    ssh-keygen -q -C retro@retrojump -f $JUMPHOME/id_rsa -N ""
  fi
  local pubkey=$(cat $JUMPHOME/id_rsa.pub)

cat > $TEMPDIR/metadata <<EOF
instance-id: retrojump-1
local-hostname: retrojump
EOF

cat > $TEMPDIR/userdata <<EOF
#cloud-config
user: retro
password: retro
chpasswd: { expire: False }
ssh_pwauth: True
ssh_authorized_keys:
  - $pubkey
packages:
  - vsftpd
write_files:
  - path: /etc/vsftpd.conf
    content: |
      listen_address=10.0.2.1
      listen=NO
      listen_ipv6=YES
      anonymous_enable=YES
      local_enable=YES
      write_enable=YES
      dirmessage_enable=YES
      use_localtime=YES
      xferlog_enable=YES
      connect_from_port_20=YES
      secure_chroot_dir=/var/run/vsftpd/empty
      pam_service_name=vsftpd
      rsa_cert_file=/etc/ssl/certs/ssl-cert-snakeoil.pem
      rsa_private_key_file=/etc/ssl/private/ssl-cert-snakeoil.key
      ssl_enable=NO
EOF

cat > $TEMPDIR/networkconfig <<EOF
network:
  version: 2
  ethernets:
    internet0:
      match:
        macaddress: "$JUMP_NET_MAC_INTERNET"
      set-name: internet0
      dhcp4: true
      routes:
        - to: 10.0.1.0/24
          via: 10.0.1.2
    retronet0:
      match:
        macaddress: "$JUMP_NET_MAC_RETRONET"
      set-name: retronet0
      addresses:
        - 10.0.2.1/24
      routes:
        - to: 10.0.2.0/24
          via: 10.0.2.2
EOF

  jump_make_seed_image
}

jump_run() {
  local seed=""
  local system_drive
  jump_check_ssh_port_available
  if [[ ! -f $JUMPIMG ]]; then
    jump_init
    seed=$(jump_seed_drive_args)
  fi
  system_drive=$(jump_system_drive_args)

  "$QEMU_BIN" \
    -nographic \
    $QEMU_MACHINE_ARGS \
    -m 2G \
    -netdev user,id=internet,net=10.0.1.0/24,hostfwd=tcp::$JUMP_SSH_PORT-:22 \
    -device $QEMU_NET_DEVICE,netdev=internet,mac=$JUMP_NET_MAC_INTERNET \
    -netdev socket,id=retronet,listen=:1234 \
    -device $QEMU_NET_DEVICE,netdev=retronet,mac=$JUMP_NET_MAC_RETRONET \
    $system_drive \
    $QEMU_EXTRA_ARGS \
    $seed \
    $@
}

jump_ssh() {
  ssh -i $JUMPHOME/id_rsa -p $JUMP_SSH_PORT retro@localhost $@
}

jump_sftp() {
  sftp -i $JUMPHOME/id_rsa -P $JUMP_SSH_PORT retro@localhost $@
}

jump_scp() {
  local arg
  local params=()

  for arg in "$@"; do
    if [[ "$arg" == retro:* ]]; then
      params+=("retro@localhost:${arg#retro:}")
    else
      params+=("$arg")
    fi
  done

  scp -i "$JUMPHOME/id_rsa" -P $JUMP_SSH_PORT "${params[@]}"
}

jump_usage() {
cat <<EOF
Usage: $(basename $0) COMMAND ...

Commands:
  run   start the jumpbox with a serial console
  ssh   ssh into jumpbox
  sftp  sftp into jumpbox
  scp   scp file into into jumpbox

Additional parameters are passed verbatim to ssh/sftp/scp.
For scp, 'retro:*' is expanded to 'retro@localhost:*'.

EOF
exit 1
}

jump_configure_platform
jump_check_platform_prereqs

if [[ $# -ge 1 ]]; then
  COMMAND=$1
  shift
  case $COMMAND in
    run) jump_run $@;;
    ssh) jump_ssh $@;;
    sftp) jump_sftp $@;;
    scp) jump_scp $@;;
    *) jump_usage;;
  esac
else
  jump_usage
fi
