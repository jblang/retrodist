#!/usr/bin/env bash
# Test CLI for QMP helpers.
set -euo pipefail

SCRIPTDIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
# shellcheck source=retrolib/qmp.sh
source "$SCRIPTDIR/retrolib/qmp.sh"

usage() {
  cat <<EOF
Usage: $(basename "$0") COMMAND [OPTIONS] [ARGS]

Commands:
  dump-screen             dump the full VGA text memory range
  send-key KEY            send a literal QEMU sendkey key sequence
  send-stdin              type stdin into the guest using QEMU sendkey commands
  send-text [-n] TEXT     type TEXT into the guest using QEMU sendkey commands
  change-image IMG        change attached image on device (defaults to floppy0)
  eject-disk [DEV]        eject disk image (defaults to floppy0)
  help                    show this help text

Common options:
  -h HOST     QMP host. Default: 127.0.0.1
  -p PORT     QMP port. Default: QEMU_QMP_BASE, normally 4444
  -a ADDR     VGA text buffer address. Default: 0xb8000
  -c COLS     Screen columns. Default: 80
  -r ROWS     Screen rows. Default: 25
  -m BYTES    VGA text memory bytes for dump-screen. Default: 32768
  -w SECONDS  nc idle timeout. Default: 1

dump-screen options:
  -n          Prefix rows with line numbers.

send-text options:
  -n          send Enter after TEXT

change-image options:
  -d DEVICE   device to change. Default: floppy0

Environment variables with the same names are also supported:
QMP_HOST, QMP_PORT, VGA_ADDR, VGA_COLS, VGA_ROWS, VGA_MEM_BYTES, QMP_TIMEOUT.
QEMU_QMP_PORT and QEMU_QMP_BASE may also set the default QMP port.
EOF
}

qmp_number_lines() {
  awk '{ printf "%02d: %s\n", NR, $0 }'
}

qmp_parse_options() {
  local optstring
  optstring=$1
  shift

  OPTIND=1
  while getopts "$optstring" opt; do
    case "$opt" in
      h) QMP_HOST=$OPTARG ;;
      p) QMP_PORT=$OPTARG ;;
      a) VGA_ADDR=$OPTARG ;;
      c) VGA_COLS=$OPTARG ;;
      r) VGA_ROWS=$OPTARG ;;
      m) VGA_MEM_BYTES=$OPTARG ;;
      w) QMP_TIMEOUT=$OPTARG ;;
      n)
        if [ "${QMP_PARSE_N_MODE:-line-numbers}" = "send-newline" ]; then
          QMP_SEND_NEWLINE=1
        else
          QMP_DUMP_LINE_NUMBERS=1
        fi
        ;;
      d) QMP_DISK=$OPTARG ;;
      *)
        usage >&2
        exit 1
        ;;
    esac
  done
  shift $((OPTIND - 1))
  QMP_REMAINING_ARGS=("$@")
}

qmp_set_defaults
QMP_DUMP_LINE_NUMBERS=${QMP_DUMP_LINE_NUMBERS:-0}
QMP_SEND_NEWLINE=${QMP_SEND_NEWLINE:-0}
QMP_DISK=${QMP_DISK:-floppy0}

command_name=${1:-help}
case "$command_name" in
  help | --help)
    usage
    exit 0
    ;;
  dump-screen | send-key | send-stdin | send-text | change-image | eject-disk)
    shift || true
    ;;
  *)
    echo "Unknown qmp command: $command_name" >&2
    echo >&2
    usage >&2
    exit 1
    ;;
esac

case "$command_name" in
  dump-screen)
    qmp_parse_options "h:p:a:c:r:m:w:n" "$@"
    ;;
  send-key)
    qmp_parse_options "h:p:w:" "$@"
    ;;
  send-stdin)
    qmp_parse_options "h:p:w:" "$@"
    ;;
  send-text)
    QMP_PARSE_N_MODE=send-newline
    qmp_parse_options "h:p:w:n" "$@"
    unset QMP_PARSE_N_MODE
    ;;
  change-image)
    qmp_parse_options "h:p:w:d:" "$@"
    ;;
  eject-disk)
    qmp_parse_options "h:p:w:d:" "$@"
    ;;
esac
set +u
set -- "${QMP_REMAINING_ARGS[@]}"
set -u

qmp_check_prereqs
qmp_vga_validate_config

case "$command_name" in
  dump-screen)
    if [ $# -ne 0 ]; then
      echo "$command_name does not take positional arguments" >&2
      exit 1
    fi
    if [ "$QMP_DUMP_LINE_NUMBERS" = "1" ]; then
      qmp_vga_dump_text | qmp_number_lines
    else
      qmp_vga_dump_text
    fi
    ;;
  send-key)
    if [ $# -ne 1 ]; then
      echo "Usage: $(basename "$0") send-key [OPTIONS] KEY" >&2
      exit 1
    fi
    qmp_sendkey "$1"
    ;;
  send-stdin)
    if [ $# -ne 0 ]; then
      echo "Usage: INPUT | $(basename "$0") send-stdin [OPTIONS]" >&2
      exit 1
    fi
    qmp_send_stdin
    ;;
  send-text)
    if [ $# -ne 1 ]; then
      echo "Usage: $(basename "$0") send-text [OPTIONS] TEXT" >&2
      exit 1
    fi
    qmp_send_string "$1"
    if [ "$QMP_SEND_NEWLINE" = "1" ]; then
      qmp_send_return
    fi
    ;;
  change-image)
    if [ $# -ne 1 ]; then
      echo "Usage: $(basename "$0") change-image [OPTIONS] IMAGE" >&2
      exit 1
    fi
    qmp_change_image "$1" "$QMP_DISK"
    ;;
  eject-disk)
    if [ $# -gt 1 ]; then
      echo "Usage: $(basename "$0") eject-disk [OPTIONS] [DEVICE]" >&2
      exit 1
    fi
    if [ $# -eq 1 ]; then
      QMP_DISK=$1
    fi
    qmp_eject_disk "$QMP_DISK"
    ;;
esac
